# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Netlify Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Frontend teacher PIN (4 digits) - teachers must enter this to access the creator
VITE_TEACHER_PIN=1234

# Backend communication
RAILWAY_API_URL=https://your-railway-app.railway.app
PIPELINE_SECRET=your-shared-secret-here-change-this

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Railway Backend Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Flask configuration
FLASK_ENV=production
PORT=5000

# Shared secret (must match Netlify PIPELINE_SECRET)
PIPELINE_SECRET=your-shared-secret-here-change-this

# ReadAloud repo (the repository where books are stored)
READALOUD_REPO_PATH=/app/readaloud

# GitHub configuration (for pushing commits after book creation)
GITHUB_TOKEN=your-github-pat-here
GITHUB_REPO=your-username/readaloud

# API Keys (same as your main readaloud project)
ANTHROPIC_API_KEY=your-anthropic-key
GEMINI_API_KEY=your-gemini-key
ELEVENLABS_API_KEY=your-elevenlabs-key
